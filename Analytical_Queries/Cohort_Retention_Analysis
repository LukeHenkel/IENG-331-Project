-- Percent of each cohort placed a second order within 30, 60, 90 days

WITH delivered_orders AS(
SELECT
order_id,
customer_id,
order_purchase_timestamp
FROM delivered_orders
WHERE order_status = 'delivered'
AND order_purchase_timestamp IS NOT NULL
),

first_orders AS(
SELECT
customer_id,
MIN(order_purchase_timestamp) AS first_order_ts
FROM delivered_orders
GROUP BY customer_id
),

second_orders AS(
SELECT
f.customer_id,
f.first_order_ts,
MIN(d.order_purchase_timestamp) AS second_order_ts
FROM first_orders f
LEFT JOIN delivered_orders d
ON f.customer_id = d.customer_id
AND d.order_purchase_timestamp > f.first_order_ts
GROUP BY f.customer_id, f.first_order_ts
),

