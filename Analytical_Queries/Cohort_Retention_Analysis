-- Percent of each cohort placed a second order within 30, 60, 90 days

WITH delivered_orders AS(
SELECT
order_id,
customer_id,
order_purchase_timestamp
FROM delivered_orders
WHERE order_status = 'delivered'
AND order_purchase_timestamp IS NOT NULL
),

first_orders AS(
SELECT
customer_id,
MIN(order_purchase_timestamp) AS first_order_ts
FROM delivered_orders
GROUP BY customer_id
),

second_orders AS(
SELECT
f.customer_id,
f.first_order_ts,
MIN(d.order_purchase_timestamp) AS second_order_ts
FROM first_orders f
LEFT JOIN delivered_orders d
ON f.customer_id = d.customer_id
AND d.order_purchase_timestamp > f.first_order_ts
GROUP BY f.customer_id, f.first_order_ts
),

cohort_retention AS(
SELECT
DATE_TRUNC('month',first_order_ts) AS cohort_month,
COUNT(*) AS cohort_size,
SUM(CASE WHEN DATE_DIFF('day',first_order_ts,second_order_ts)<= 30 THEN 1 ELSE 0) AS retained_30d,
SUM(CASE WHEN DATE_DIFF('day',first_order_ts,second_order_ts)<=60 THEN 1 ELSE 0) AS retained_60d,
SUM(CASE WHEN DATE_DIFF('day',first_order_ts,second_order_ts)<=90 THEN 1 ELSE 0) AS retained_90d
FROM second_orders
GROUP BY DATE_TRUNC('month',first_order_ts)
)

SELECT
cohort_month,
cohort_size,
retained_30d,
ROUND(100.0*retained_30d / cohort_size, 2) AS retained_30d_pct,
retained_60d,
ROUND(100.0*retained_60d / cohort_size, 2) AS retained_60d_pct,
retained_90d,
ROUND(100.0*retained_90d / cohort_size, 2) AS retained_90d_pct
FROM cohort_retention
ORDER BY cohort_month;