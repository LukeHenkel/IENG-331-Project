--Rank sellers by a composite score combining rev-enue, on-time delivery rate, average review score, and return/cancellation rate

WITH seller_revenue AS (
    SELECT
        oi.seller_id,
        COUNT(DISTINCT oi.order_id) AS delivered_orders,
        SUM(oi.price + oi.freight_value) AS gross_revenue
    FROM order_items oi
    JOIN orders o
    ON oi.order_id = o.order_id
    WHERE o.order_status = 'delivered'
    GROUP BY oi.seller_id
),

seller_delivery AS (
    SELECT
        oi.seller_id,
        COUNT(*) AS delivered_items,
        SUM(
        CASE
            WHEN o.order_delivered_customer_date <= o.order_estimated_delivery_date
            THEN 1 ELSE 0
        END
    ) AS on_time_items
    FROM order_items oi
    JOIN orders o
    ON oi.order_id = o.order_id
    WHERE o.order_status = 'delivered'
    AND o.order_delivered_customer_date IS NOT NULL
    AND o.order_estimated_delivery_date IS NOT NULL
    GROUP BY oi.seller_id
    ),

seller_reviews AS(
    SELECT
        oi.seller_id
        AVG(r.review_score) AS avg_review_score
    FROM order_items oi
    JOIN orders o
    ON oi.order_id = o.order_id
    JOIN order_reviews r
    ON o.order_id = r.order_id
    WHERE o.order_status = 'delivered'
    GROUP BY oi.seller_id
    ),

seller_cancellations AS (
    SELECT
        oi.seller_id,
        COUNT(DISTINCT oi.order_id) AS total_orders,
        COUNT(DISTINCT CASE WHEN o.order_status IN('canceled','unavailable') THEN oi.order_id END) AS bad_orders
    FROM order_items oi
    JOIN orders o
    ON oi.order_id = o.order_id
    GROUP BY oi.seller_id
    ),

seller_scorecard AS (
    SELECT
        sr.seller.id,
        sr.delivered_orders,
        ROUND(sr.gross_revenue,2) AS gross_revenue,
        ROUND(100.0*sd.on_time_items / sd.delivered_items,2) AS on_time_rate_pct,
        ROUND(srv.avg_review_score,2) AS avg_review_score,
        ROUND(100.0*sc.bad_orders / sc.total_orders,2) AS bad_order_rate_pct
    FROM seller_revenue sr
    JOIN seller_delivery sd
    ON sr.seller_id = sd.seller_id
    JOIN seller_reviews srv
    ON sr.seller_id = srv.seller_id
    JOIN seller_cancellations sc
    on sr.seller_id = sc.seller_id
    WHERE sr.delivered_orders>=10
    )

SELECT
    seller_id,
    delivered_orders,
    gross_revenue,
    on_time_rate_pct,
    avg_review_score,
    bad_order_rate_pct,
    RANK()OVER(
    ORDER BY gross_revenue DESC,
    on_time_rate_pct DESC,
    avg_review_score DESC,
    bad_order_rate_pct ASC
    ) AS seller_rank
FROM seller_scorecard
ORDER BY seller_rank
LIMIT 25;